{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Check MSPM0/J-Link Environment",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/check_env.sh",
      "problemMatcher": []
    },
    {
      "label": "Configure Main Firmware",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/build.sh",
      "args": ["--configure-only"],
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Build Main Firmware",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/build.sh",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Flash Main Firmware (J-Link)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/flash_jlink.sh",
      "dependsOrder": "sequence",
      "dependsOn": "Build Main Firmware",
      "problemMatcher": []
    },
    {
      "label": "Start J-Link GDB Server",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/jlink_gdb_server.sh",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Serial Monitor 115200",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/serial_monitor.sh",
      "args": ["${input:serialPort}", "115200"],
      "isBackground": true,
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "serialPort",
      "type": "promptString",
      "description": "USB Type-C serial device",
      "default": "/dev/ttyUSB0"
    }
  ]
}
