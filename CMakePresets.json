{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "mspm0-gcc-debug",
      "displayName": "MSPM0 Main Firmware (Debug)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-fw",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-none-eabi-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "main-build",
      "configurePreset": "mspm0-gcc-debug"
    }
  ]
}
